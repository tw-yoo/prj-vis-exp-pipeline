{
  "chart_family": "bar_simple",
  "mark": "bar",
  "dimensions": {
    "width": 640,
    "height": 360,
    "margin": {
      "top": 32,
      "right": 24,
      "bottom": 56,
      "left": 64
    }
  },
  "fields": {
    "x": {
      "field": "Year",
      "type": "nominal",
      "title": "Year"
    },
    "y": {
      "field": "Revenue multiple",
      "type": "quantitative",
      "title": "Revenue multiple"
    }
  },
  "row_count": 15,
  "supported_vl_properties": [
    "mark",
    "encoding.x",
    "encoding.y",
    "encoding.color",
    "width",
    "height",
    "axis.title",
    "encoding.sort",
    "mark.color/fill/stroke"
